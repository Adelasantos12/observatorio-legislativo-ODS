{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IHR2024Change",
  "description": "IHR 2024 amendments and new provisions",
  "type": "object",
  "properties": {
    "change_id": {
      "type": "string"
    },
    "article_or_annex": {
      "type": "string"
    },
    "type_of_change": {
      "type": "string"
    },
    "new_or_modified_concept": {
      "type": "string"
    },
    "change_summary": {
      "type": "string"
    },
    "creates_new_domestic_requirement": {
      "type": "string"
    },
    "modifies_existing_requirement": {
      "type": "string"
    },
    "requires_legal_review": {
      "type": "string"
    },
    "relevant_ihr2005_obligation_id": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false,
  "required": [
    "change_id",
    "article_or_annex",
    "new_or_modified_concept"
  ]
}