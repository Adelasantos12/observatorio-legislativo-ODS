# Frontend del Escáner Legislativo MX (config .env.mx).
# La URL del backend se hornea en build (Vite): pásala con
#   --build-arg VITE_VUE_APP_BACKEND_URL=https://<api>.up.railway.app
# En Railway, define esa variable en el servicio del frontend (se expone como
# build arg vía ARG/ENV abajo).

# build stage
FROM node:lts-alpine AS build-stage

RUN apk update && apk add git

WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci || npm install
COPY . .

# Base: configuración mexicana. Se puede sobreescribir la URL del backend.
RUN cp .env.mx .env.production
ARG VITE_VUE_APP_BACKEND_URL
ENV VITE_VUE_APP_BACKEND_URL=${VITE_VUE_APP_BACKEND_URL}
# Si se pasó el build-arg, reemplaza la línea del backend en .env.production.
RUN if [ -n "$VITE_VUE_APP_BACKEND_URL" ]; then \
        sed -i "s#^VITE_VUE_APP_BACKEND_URL=.*#VITE_VUE_APP_BACKEND_URL=${VITE_VUE_APP_BACKEND_URL}#" .env.production; \
    fi
RUN npm run build

# production stage
FROM nginx:stable-alpine AS production-stage
COPY --from=build-stage /app/dist /usr/share/nginx/html
# nginx debe escuchar en el puerto que asigna Railway ($PORT), no en 80 fijo, o
# el proxy devuelve "Application failed to respond". La imagen nginx sustituye
# ${PORT} en las plantillas de /etc/nginx/templates al arrancar.
COPY nginx.conf.template /etc/nginx/templates/default.conf.template
ENV PORT=80 \
    NGINX_ENVSUBST_FILTER=PORT
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
