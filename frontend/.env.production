# Configuración de build de producción = despliegue mexicano (equivale a .env.mx).
# La usa `npm run build`. Dockerfile-mx la regenera desde .env.mx en el build.
VITE_VUE_APP_SHORTNAME='escaner-mx'
VITE_VUE_APP_BACKEND_URL=http://localhost:8080
VITE_VUE_APP_USE_ALERTS=false
VITE_KNOWLEDGEBASE=mx
VITE_DEFAULT_LOCALE=es
VITE_FALLBACK_LOCALE=es
VITE_VUE_APP_TITLE='Escáner Legislativo MX — Huella internacional de la legislación mexicana'
VITE_GA_ID=
