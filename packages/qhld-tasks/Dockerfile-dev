FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends git gcc \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

# El venv vive en /app/.venv (fuera de /app/packages) para que el bind-mount de
# desarrollo (./packages:/app/packages en docker-compose) no lo oculte.
ENV UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy \
    UV_PYTHON_DOWNLOADS=0 \
    UV_PROJECT_ENVIRONMENT=/app/.venv

WORKDIR /app/packages/qhld-tasks

# Contexto de build = raíz del monorepo. Copiamos todo packages/ para que el
# path-dep editable qhld-data (../qhld-data) resuelva al instalar.
COPY packages /app/packages

RUN --mount=type=cache,target=/root/.cache/uv \
    uv sync --locked --no-install-project

# tipi_tasks se sirve desde el código montado (PYTHONPATH), no como paquete
# instalado, para que el worker recoja cambios del host.
# Cerebro jurídico + esquema NormTrace (etapa 3) en la imagen; sus defaults se
# resuelven en /app/normtrace.
COPY normtrace /app/normtrace

ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONPATH=/app/packages/qhld-tasks

# Consume la cola por defecto y la de codificación NormTrace.
CMD ["celery", "-A", "tipi_tasks", "worker", "-Q", "celery,normtrace", "-B", "-l", "info"]
